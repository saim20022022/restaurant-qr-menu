{
  "name": "restaurant-qr-menu",
  "version": "1.0.0",
  "private": true,
  "description": "Single-tenant Restaurant QR Menu monorepo (NestJS + Next.js + Prisma)",
  "packageManager": "pnpm@9.12.2",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @restaurant/api --filter @restaurant/web dev",
    "dev:api": "pnpm --filter @restaurant/api dev",
    "dev:web": "pnpm --filter @restaurant/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "prisma:generate": "pnpm --filter @restaurant/api prisma:generate",
    "prisma:migrate": "pnpm --filter @restaurant/api prisma:migrate",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "clean": "pnpm -r exec rimraf dist .next"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
